{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "Sentinel Lines Processed",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(sentinel_lines_processed_total[1m])", "refId": "A", "legendFormat": "lines/sec" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Alerts by Category",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (category) (rate(sentinel_alerts_total[1m]))", "refId": "A", "legendFormat": "{{category}}" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "id": 3,
      "title": "Alert Rate Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(sentinel_alerts_total[1m]))", "refId": "A", "legendFormat": "alerts/sec" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "id": 4,
      "title": "Top Attacking IPs",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum by (source_ip) (sentinel_alerts_by_source_ip_total))", "refId": "A", "legendFormat": "{{source_ip}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 5,
      "title": "Most Targeted URLs",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "topk(10, sum by (path) (sentinel_alerts_by_path_total))", "refId": "A", "legendFormat": "{{path}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
